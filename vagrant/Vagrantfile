# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Flynn Cluster Vagrantfile (libvirt provider, Debian 13)
#
# Usage:
#   Single-node:   vagrant up node1
#   Three-node:    NUM_NODES=3 AUTO_BOOTSTRAP=false vagrant up --no-parallel
#   Custom domain: CLUSTER_DOMAIN=test.localflynn.com NUM_NODES=3 vagrant up --no-parallel
#
# IMPORTANT: Multi-node clusters MUST use --no-parallel to avoid libvirt
# race conditions when creating multiple VMs simultaneously.
#
# Requirements:
#   - vagrant-libvirt plugin
#   - KVM acceleration (/dev/kvm)
#   - debian13-amd64 box added: vagrant box add debian13-amd64 /path/to/debian13-amd64.box
#
# On the x86_64 dev-machine (192.168.168.87):
#   vagrant box add debian13-amd64 /root/vagrant-boxes/debian13-amd64.box
#   cd /path/to/this/directory && vagrant up
#

VAGRANTFILE_API_VERSION = "2"

# --- Configuration -----------------------------------------------------------

# Number of nodes: 1 (singleton) or 3+ (multi-node; Flynn rejects 2)
NUM_NODES       = (ENV["NUM_NODES"] || "1").to_i

# Resources per node
# Multi-node HA runs ~13 jobs per node at 1 GiB default each.
# 4 GB is fine for single-node (singleton reduces to ~16 processes total).
# 8 GB gives headroom for HA (13 × 1 GiB + OS overhead).
DEFAULT_MEMORY  = NUM_NODES > 1 ? 8192 : 4096
NODE_MEMORY     = (ENV["NODE_MEMORY"] || DEFAULT_MEMORY.to_s).to_i  # MB
NODE_CPUS       = (ENV["NODE_CPUS"] || (NUM_NODES > 1 ? "4" : "2")).to_i
NODE_DISK_SIZE  = (ENV["NODE_DISK_SIZE"] || "40").to_i  # GB, for ZFS pool

# Networking
# Private network subnet for inter-node communication.
# Nodes get IPs: 192.168.50.11, 192.168.50.12, ...
PRIVATE_SUBNET  = "192.168.50"
NODE_IP_START   = 11

# Flynn settings
CLUSTER_DOMAIN  = ENV["CLUSTER_DOMAIN"] || "demo.localflynn.com"
FLYNN_REPO_URL  = ENV["FLYNN_REPO_URL"] || "https://consolving.github.io/flynn-tuf-repo/repository"
AUTO_BOOTSTRAP  = ENV["AUTO_BOOTSTRAP"] != "false"  # set to "false" to skip bootstrap

# Path to a locally-built flynn-host binary (for testing patches before TUF republish).
# The binary will be copied into the VM via the synced /vagrant-data directory.
# Set to "" or unset to download from TUF repo instead.
LOCAL_FLYNN_HOST = ENV["LOCAL_FLYNN_HOST"] || ""

# --- Derived values -----------------------------------------------------------

# Build the list of all node IPs for --peer-ips
NODE_IPS = (0...NUM_NODES).map { |i| "#{PRIVATE_SUBNET}.#{NODE_IP_START + i}" }

# --- Validation ---------------------------------------------------------------

if NUM_NODES == 2
  abort "ERROR: Flynn rejects --min-hosts=2. Use 1 (singleton) or 3+ nodes."
end

# --- VM definitions -----------------------------------------------------------

Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|
  config.vm.box = "debian13-amd64"
  config.ssh.insert_key = false

  # Increase SSH keep-alive frequency to prevent Vagrant from killing
  # long-running provisioners (e.g., DKMS ZFS kernel module compilation
  # takes 4+ minutes with no stdout when output is suppressed).
  config.ssh.keep_alive = true

  # Generous boot timeout to allow for slow DKMS kernel module builds
  # during provisioning (ZFS DKMS takes 4-6 minutes).
  config.vm.boot_timeout = 900            # seconds to wait for VM to boot
  config.vm.graceful_halt_timeout = 120   # seconds to wait for graceful shutdown

  # Disable default synced folder (not needed, avoids rsync/nfs issues)
  config.vm.synced_folder ".", "/vagrant", disabled: true

  (1..NUM_NODES).each do |i|
    node_name = "node#{i}"
    node_ip   = "#{PRIVATE_SUBNET}.#{NODE_IP_START + i - 1}"

    config.vm.define node_name, primary: (i == 1) do |node|
      node.vm.hostname = node_name

      # Private network for inter-node communication
      node.vm.network :private_network,
        ip: node_ip,
        libvirt__network_name: "flynn-cluster",
        libvirt__dhcp_enabled: false

      # libvirt provider settings
      node.vm.provider :libvirt do |libvirt|
        libvirt.driver = "kvm"
        libvirt.memory = NODE_MEMORY
        libvirt.cpus   = NODE_CPUS

        # Assign a deterministic MAC on the management network so each VM
        # gets a unique DHCP lease.  Without this, vagrant-libvirt can hand
        # the same IP to multiple VMs in multi-node setups, which breaks SSH.
        libvirt.management_network_mac = "52:54:00:FE:00:%02X" % i

        # Additional disk for ZFS pool
        libvirt.storage :file,
          size: "#{NODE_DISK_SIZE}G",
          type: "qcow2",
          bus: "virtio",
          device: "vdb"
      end

      # Upload local flynn-host binary if specified
      if LOCAL_FLYNN_HOST != ""
        node.vm.provision "upload-binary", type: "file",
          source: LOCAL_FLYNN_HOST,
          destination: "/tmp/flynn-host-local"
      end

      # Phase 1: System provisioning + daemon start (all nodes)
      # Everything is done in a single provisioner to avoid a vagrant-libvirt
      # bug where subsequent provisioners get triggered before the shell
      # provisioner finishes on node2/node3 during long-running DKMS builds.
      provision_args = [
        "--node-ip", node_ip,
        "--repo-url", FLYNN_REPO_URL,
      ]
      if LOCAL_FLYNN_HOST != ""
        provision_args += ["--local-binary", "/tmp/flynn-host-local"]
      end
      node.vm.provision "system", type: "shell", privileged: true, path: "provision.sh", args: provision_args

      # Phase 2: Bootstrap (last node only, after all nodes are up)
      # We run bootstrap on the LAST node so that all previous nodes'
      # daemons are already running when bootstrap's check-online-hosts runs.
      if i == NUM_NODES && AUTO_BOOTSTRAP
        node.vm.provision "bootstrap", type: "shell", privileged: true, inline: <<-SCRIPT
          set -eo pipefail

          echo "==> Waiting for all peer daemons to be reachable..."
          for peer_ip in #{NODE_IPS.join(" ")}; do
            for attempt in $(seq 1 30); do
              if curl -sf "http://${peer_ip}:1113/host/status" >/dev/null 2>&1; then
                echo "    peer ${peer_ip} is ready"
                break
              fi
              echo "    waiting for peer ${peer_ip} (attempt ${attempt}/30)..."
              sleep 2
            done
            if ! curl -sf "http://${peer_ip}:1113/host/status" >/dev/null 2>&1; then
              echo "ERROR: peer ${peer_ip} did not become ready"
              exit 1
            fi
          done

          echo "==> All #{NUM_NODES} peers are online. Running bootstrap..."
          CLUSTER_DOMAIN="#{CLUSTER_DOMAIN}" \\
          flynn-host bootstrap \\
            --min-hosts=#{NUM_NODES} \\
            --peer-ips=#{NODE_IPS.join(",")} \\
            --timeout=600 \\
            2>&1 | tee /var/log/flynn/bootstrap.log

          echo "==> Bootstrap complete!"
          echo "    Cluster domain: #{CLUSTER_DOMAIN}"
          echo "    Dashboard:      https://dashboard.#{CLUSTER_DOMAIN}"
        SCRIPT
      end
    end
  end
end
